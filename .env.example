# ============================================================
# fotowisuda.ai — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# Leonardo.ai API Key (required)
# Generate one at: https://app.leonardo.ai/api-access
LEONARDO_API_KEY=your_leonardo_api_key_here

# Google Gemini API Key (required for Background Swap Tool)
# Generate one at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Anthropic API Key (required for Background Change by Claude)
# Generate one at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Server port (optional, defaults to 3000)
PORT=3000
